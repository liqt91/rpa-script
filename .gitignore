# Generated workflow scripts — auto-created by workflow exporter
src/service/local_jobs/_generated/

# Compiled workflow-editor build artifacts
src/runtime/static/workflow-editor/assets/
src/runtime/static/workflow-editor/*.js
src/runtime/static/workflow-editor/*.map

# Python cache
__pycache__/
*.pyc

# Runtime data & telemetry
data/data.db
.harness/telemetry.jsonl

# Private jobs / internal examples not shipped in the open-source repo
.private/

# Build artifacts and local environment
dist/
build/
*.exe
*.zip
.env
server.log

# Runtime logs, temp deliverables and generated data
src/data/run_logs/
tmp/
open-source-readiness.html

# Harness session/runtime state (regenerated per session)
.harness/PROGRESS.md
.harness/compaction-snapshot.json
.harness/memory/current-summary.md
.harness/memory/ledger.jsonl
.harness/project/state.json
.harness/state/session-pill.stamp
