# rpa_script 环境变量示例
# 复制本文件为 .env 并填入实际值后启动服务

# 必填：JWT 签名密钥，请使用强随机字符串（如 openssl rand -hex 32）
SECRET_KEY=your-strong-secret-key-here

# 可选：数据库 URL，留空则使用项目根目录 data/data.db (SQLite)
# DATABASE_URL=sqlite:///data/data.db

# AI: Dify 配置（可选，未配置时 AI 相关指令不可用）
DIFY_BASE_URL=https://your-dify-instance.example.com
DIFY_SENTIMENT_KEY=
DIFY_SENTIMENT_TYPE=chat
DIFY_STANCE_KEY=
DIFY_STANCE_TYPE=chat
DIFY_SUMMARY_KEY=
DIFY_SUMMARY_TYPE=chat
DIFY_TOPICS_KEY=
DIFY_TOPICS_TYPE=chat
DIFY_COMMENT_ANALYSIS_KEY=
DIFY_COMMENT_ANALYSIS_TYPE=chat
DIFY_COMMENT_ANALYSIS_JINGPIN_KEY=
DIFY_COMMENT_ANALYSIS_JINGPIN_TYPE=chat

# 兼容：OpenAI 配置（可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_DEFAULT_MODEL=gpt-4o-mini

# 更新检查：私有 Gitea 实例（可选，开源后建议关闭或指向 GitHub Releases）
GITEA_BASE_URL=
GITEA_REPO_OWNER=
GITEA_REPO_NAME=

# 服务端绑定
HOST=0.0.0.0
PORT=8000
