{
  "manifest_version": 3,
  "name": "操作编排器",
  "version": "1.0",
  "description": "可视化录制网页操作流程，导出为 JSON 或自然语言描述",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "clipboardWrite",
    "scripting",
    "webNavigation",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "操作编排器"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_stub.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+O"
      },
      "description": "打开操作编排器面板"
    }
  }
}
