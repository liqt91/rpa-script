{
  "cmd": "pressKey",
  "label": "按键",
  "runtime": "extension",
  "category": "页面操作",
  "icon": "fa-keyboard",
  "iconColor": "text-purple-500",
  "bgColor": "bg-purple-50",
  "categoryOrder": 60,
  "commandOrder": 30,
  "description": "向页面发送键盘按键。OS级keybd_event发送，页面按键和浏览器快捷键均可生效",
  "enabled": true,
  "params": [
    {
      "name": "key",
      "label": "按键",
      "type": "select",
      "required": true,
      "default": "Enter",
      "description": "[页面]仅页面生效  [浏览器]整个浏览器生效  [需modifier]请填写修饰键",
      "options": [
        {"label": "Enter 回车 [页面]", "value": "Enter"},
        {"label": "Tab 制表 [页面]", "value": "Tab"},
        {"label": "Escape 取消 [页面]", "value": "Escape"},
        {"label": "Backspace 退格 [页面]", "value": "Backspace"},
        {"label": "Delete 删除 [页面]", "value": "Delete"},
        {"label": "Space 空格 [页面]", "value": " "},
        {"label": "ArrowUp \u2191 [页面]", "value": "ArrowUp"},
        {"label": "ArrowDown \u2193 [页面]", "value": "ArrowDown"},
        {"label": "ArrowLeft \u2190 [页面]", "value": "ArrowLeft"},
        {"label": "ArrowRight \u2192 [页面]", "value": "ArrowRight"},
        {"label": "PageUp 上翻 [页面]", "value": "PageUp"},
        {"label": "PageDown 下翻 [页面]", "value": "PageDown"},
        {"label": "Home [页面]", "value": "Home"},
        {"label": "End [页面]", "value": "End"},
        {"label": "F1 [浏览器]", "value": "F1"},
        {"label": "F5 刷新 [浏览器]", "value": "F5"},
        {"label": "F12 开发者工具 [浏览器]", "value": "F12"},
        {"label": "Ctrl+C 复制 [需modifier=Ctrl]", "value": "c"},
        {"label": "Ctrl+V 粘贴 [需modifier=Ctrl]", "value": "v"},
        {"label": "Ctrl+A 全选 [需modifier=Ctrl]", "value": "a"},
        {"label": "Ctrl+Z 撤销 [需modifier=Ctrl]", "value": "z"}
      ]
    },
    {
      "name": "modifiers",
      "label": "修饰键",
      "type": "string",
      "default": "",
      "placeholder": "Ctrl,Alt,Shift, 可多个逗号分隔",
      "group": "advanced",
      "description": "同时按下的修饰键。Ctrl+C/V/A/Z 需要 modifier=Ctrl。注意：Ctrl+T/W/N 等浏览器标签页快捷键也会生效"
    }
  ],
  "categories": [
    "page"
  ],
  "handler": {
    "kind": "extension",
    "source": "extension/dom_handlers_new/pressKey.js"
  }
}