{
  "label": "打开浏览器",
  "runtime": "extension",
  "category": "浏览器",
  "icon": "fa-globe",
  "iconColor": "text-blue-500",
  "bgColor": "bg-blue-50",
  "categoryOrder": 10,
  "commandOrder": 10,
  "description": "启动浏览器并加载RPA扩展",
  "enabled": true,
  "params": [
    {
      "name": "browserType",
      "label": "浏览器",
      "type": "select",
      "options": [
        {
          "label": "Chrome",
          "value": "chrome"
        },
        {
          "label": "Edge",
          "value": "edge"
        }
      ],
      "default": "chrome"
    },
    {
      "name": "url",
      "label": "启动后打开网址",
      "type": "string",
      "placeholder": "留空则打开 about:blank",
      "default": "about:blank"
    },
    {
      "name": "windowState",
      "label": "窗口状态",
      "type": "select",
      "options": [
        {
          "label": "普通",
          "value": "normal"
        },
        {
          "label": "最大化",
          "value": "maximized"
        },
        {
          "label": "最小化",
          "value": "minimized"
        }
      ],
      "default": "normal",
      "group": "advanced"
    },
    {
      "name": "windowVar",
      "label": "保存窗口对象到",
      "type": "string",
      "default": "browser1",
      "group": "output",
      "valueType": "window"
    }
  ],
  "categories": [
    "browser"
  ],
  "featureFlag": "core",
  "cmd": "launchBrowser"
}