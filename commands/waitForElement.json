{
  "cmd": "waitForElement",
  "label": "等待元素出现",
  "runtime": "extension",
  "category": "页面操作",
  "icon": "fa-eye",
  "iconColor": "text-yellow-500",
  "bgColor": "bg-yellow-50",
  "categoryOrder": 20,
  "commandOrder": 40,
  "description": "等待页面上的元素出现，轮询检测直到出现或超时",
  "enabled": true,
  "params": [
    {
      "name": "elementName",
      "label": "目标元素",
      "type": "element",
      "group": "主属性",
      "placeholder": "选择一个已捕获的元素"
    },
    {
      "name": "timeout",
      "label": "超时时间（秒）",
      "type": "number",
      "default": 10,
      "group": "默认属性",
      "description": "超过此时间元素未出现则失败"
    },
    {
      "name": "visibilityMode",
      "label": "可见性",
      "type": "select",
      "options": [
        {
          "label": "仅可见",
          "value": "visible"
        },
        {
          "label": "所有",
          "value": "any"
        }
      ],
      "default": "visible",
      "group": "advanced"
    }
  ],
  "categories": [
    "page"
  ]
}