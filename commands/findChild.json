    },
    {
      "name": "classFilter",
      "label": "控件类名",
      "type": "select",
      "options": [
        {
          "label": "Edit (输入框)",
          "value": "Edit"
        },
        {
          "label": "Button (按钮)",
          "value": "Button"
        },
        {
          "label": "ComboBox (下拉框)",
          "value": "ComboBox"
        },
        {
          "label": "ComboBoxEx32",
          "value": "ComboBoxEx32"
        },
        {
          "label": "Static (标签)",
          "value": "Static"
        },
        {
          "label": "ListBox (列表框)",
          "value": "ListBox"
        },
        {
          "label": "ListView (列表视图)",
          "value": "SysListView32"
        },
        {
          "label": "TreeView (树形视图)",
          "value": "SysTreeView32"
        },
        {
          "label": "不筛选",
          "value": ""
        }
