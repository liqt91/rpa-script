{
  "cmd": "switchTab",
  "label": "切换标签页",
  "runtime": "extension",
  "category": "浏览器",
  "icon": "fa-exchange-alt",
  "iconColor": "text-blue-500",
  "bgColor": "bg-blue-50",
  "categoryOrder": 10,
  "commandOrder": 40,
  "description": "切换到指定标签页。默认激活的；有 urlPattern 时匹配 URL",
  "enabled": true,
  "params": [
    {
      "name": "windowVar",
      "label": "浏览器窗口",
      "type": "string",
      "default": "browser1",
      "group": "input",
      "valueType": "window",
      "placeholder": "如 browser1"
    },
    {
      "name": "urlPattern",
      "label": "URL 匹配",
      "type": "string",
      "placeholder": "URL 包含的文本，留空使用激活标签页",
      "group": "advanced"
    }
  ],
  "handler": {
    "kind": "extension",
    "source": "extension/background_handlers/switchTab.js"
  },
  "categories": ["browser"]
}
