{
  "cmd": "newTab",
  "label": "新建标签页",
  "runtime": "extension",
  "category": "浏览器",
  "icon": "fa-plus-square",
  "iconColor": "text-blue-500",
  "bgColor": "bg-blue-50",
  "categoryOrder": 10,
  "commandOrder": 20,
  "description": "在指定浏览器窗口中新建标签页",
  "enabled": true,
  "params": [
    {
      "name": "windowVar",
      "label": "浏览器窗口",
      "type": "string",
      "default": "browser1",
      "group": "input",
      "valueType": "window",
      "placeholder": "如 browser1"
    },
    {
      "name": "url",
      "label": "打开网址",
      "type": "string",
      "placeholder": "如 https://deepseek.com"
    },
    {
      "name": "active",
      "label": "激活新标签页",
      "type": "boolean",
      "default": true,
      "group": "advanced"
    }
  ],
  "handler": {
    "kind": "extension",
    "source": "extension/background_handlers/newTab.js"
  },
  "categories": [
    "browser"
  ]
}
