{
  "label": "输入文本",
  "runtime": "extension",
  "icon": "fa-keyboard",
  "iconColor": "text-blue-500",
  "bgColor": "bg-blue-50",
  "categoryOrder": 40,
  "commandOrder": 20,
  "description": "在页面输入框中输入文本，可选输入完成后按回车",
  "enabled": true,
  "isNew": true,
  "params": [
    {
      "name": "element_name",
      "label": "元素",
      "type": "element",
      "required": true
    },
    {
      "name": "text",
      "label": "输入内容",
      "type": "string",
      "required": true
    },
    {
      "name": "pressEnter",
      "label": "输入后按回车",
      "type": "boolean",
      "default": false
    },
    {
      "name": "scope",
      "label": "匹配范围",
      "type": "select",
      "options": [
        {
          "label": "当前外层元素内",
          "value": "local"
        },
        {
          "label": "全页面",
          "value": "global"
        }
      ],
      "default": "local",
      "group": "advanced"
    },
    {
      "name": "loopAnchor",
      "label": "锚点元素",
      "type": "string",
      "default": "",
      "group": "anchor"
    },
    {
      "name": "visibilityMode",
      "label": "元素可见性",
      "type": "select",
      "options": [
        {
          "label": "仅可见",
          "value": "visible"
        },
        {
          "label": "所有",
          "value": "any"
        }
      ],
      "default": "visible",
      "group": "advanced"
    }
  ],
  "pythonAction": "input",
  "handler": {
    "kind": "extension",
    "function": "doInput"
  },
  "categories": [
    "element"
  ],
  "cmd": "inputElement"
}